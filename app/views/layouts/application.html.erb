<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Calendar App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' %>
    <%= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js' %>
    <%= yield :head %>
    
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
    <body>
<nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm px-4 py-3">
  <div class="container-fluid d-flex justify-content-between align-items-center">
    <% if user_signed_in? %>
      <div class="d-flex align-items-center text-white">
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "rounded-circle shadow", size: "40x40" %>
        <% end %>
        <span class="fw-semibold">Witaj, <%= current_user.username %>!</span>
      </div>
      <div>
        <%= link_to 'Edycja profilu', edit_user_registration_path, class: 'btn btn-light btn-sm me-2' %>
        <%= button_to 'Wyloguj', destroy_user_session_path, method: :delete, class: 'btn btn-outline-danger btn-sm' %>
      </div>
    <% else %>
      <div>
        <%= link_to 'Zaloguj', new_user_session_path, class: 'btn btn-outline-light me-2 btn-sm' %>
        <%= link_to 'Zarejestruj się', new_user_registration_path, class: 'btn btn-outline-success btn-sm' %>
      </div>
    <% end %>
  </div>
</nav>
<br>
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-12">
          <%= yield %>
        </div>
      </div>
    </div>

    <% if flash[:notice] %>
      <script>
        alert("<%= flash[:notice] %>");
        window.location.reload();
      </script>
    <% end %>

    <% if flash[:alert] %>
      <script>
        alert("<%= flash[:alert] %>");
        window.location.reload();
      </script>
    <% end %>
  </body>