<h2 class="text-center mb-4">Rejestracja</h2>

<div class="row justify-content-center">
  <div class="col-md-6">
    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), local: true, html: { multipart: true } do |f| %>
        <% if resource.errors.any? %>
      <div class="alert alert-danger">
        <h5 class="mb-3">Wystąpiły błędy:</h5>
        <ul class="mb-0">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
      <div class="mb-3">
        <%= f.label :username, "Nazwa użytkownika", class: "form-label" %>
        <%= f.text_field :username, autofocus: true, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :email, "Adres e-mail", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :avatar, "Avatar", class: "form-label" %>
        <%= f.file_field :avatar, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Hasło", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Potwierdź hasło", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control", required: true %>
      </div>

      <%= f.submit "Zarejestruj się", class: "btn btn-success w-100" %>
    <% end %>

    <div class="text-center mt-3">
      <%= link_to "Masz już konto? Zaloguj się", new_session_path(resource_name), class: "d-block small" %>
    </div>
  </div>
</div>
