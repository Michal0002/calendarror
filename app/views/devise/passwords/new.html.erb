<h2 class="text-center mb-4">Resetowanie hasła</h2>

<div class="row justify-content-center">
  <div class="col-md-6">
    <%= form_with model: resource, as: resource_name, url: password_path(resource_name), local: true do |f| %>
        <% if resource.errors.any? %>
          <div class="alert alert-danger">
            <h5 class="mb-3">Wystąpiły błędy:</h5>
            <ul class="mb-0">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

      <div class="mb-3">
        <%= f.label :email, "Adres e-mail", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true %>
      </div>

      <%= f.submit "Wyślij instrukcje", class: "btn btn-primary w-100" %>
    <% end %>
  </div>
</div>
