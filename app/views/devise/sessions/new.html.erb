<h2 class="text-center mb-4">Logowanie</h2>

<div class="row justify-content-center">
  <div class="col-md-6">
    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), local: true do |f| %>
        <% if resource.errors.any? %>
      <div class="alert alert-danger">
        <h5 class="mb-3">Wystąpiły błędy:</h5>
        <ul class="mb-0">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
      <div class="mb-3">
        <%= f.label :login, "Nazwa użytkownika lub adres e-mail", class: "form-label" %>
        <%= f.text_field :login, autofocus: true, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Hasło", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true %>
      </div>

      <div class="mb-3 form-check">
        <%= f.check_box :remember_me, class: "form-check-input" %>
        <%= f.label :remember_me, "Zapamiętaj mnie", class: "form-check-label" %>
      </div>

      <%= f.submit "Zaloguj się", class: "btn btn-primary w-100" %>
    <% end %>

    <div class="text-center mt-3">
      <%= link_to "Nie pamiętasz hasła?", new_password_path(resource_name), class: "d-block small" %>
      <%= link_to "Zarejestruj się", new_registration_path(resource_name), class: "d-block small mt-2" %>
    </div>
  </div>
</div>
